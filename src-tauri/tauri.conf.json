{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Feathering Analysis",
  "version": "3.0.0",
  "identifier": "com.geoview.feathering-analysis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Feathering Analysis",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "python/backend.py": "python/backend.py",
      "python/Parser_2.py": "python/Parser_2.py",
      "python/requirements.txt": "python/requirements.txt"
    }
  }
}
